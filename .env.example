# Backend environment example
# Copy to .env and fill values

PORT=4000
# Set this to your frontend dev origin. Default Vite dev server in this repo runs on 8080.
CORS_ORIGIN=http://localhost:8080

# SendGrid (preferred) or leave blank to fallback to SMTP / local file
SENDGRID_API_KEY=
SENDGRID_FROM=hello@example.com

# SMTP fallback (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional reCAPTCHA secret (v2/v3) verify in server if enabled
RECAPTCHA_SECRET=

# Admin token for protected endpoints (simple shared secret)
ADMIN_TOKEN=replace-with-a-secure-token
